{
    "name": "ticketpark/saferpay-json-api",
    "type": "library",
    "description": "A php library to use the json api of Saferpay",
    "keywords": ["saferpay"],
    "homepage": "https://github.com/Ticketpark/SaferpayJsonApi",
    "license": "MIT",
    "authors": [
        {
            "name": "Manuel Reinhard",
            "email": "manuel.reinhard@ticketpark.ch"
        },
        {
            "name": "Additional contributors",
            "homepage": "https://github.com/Ticketpark/SaferpayJsonApi/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.3",
        "jms/serializer": "^3.20",
        "psr/http-client": "^1.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.80",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ticketpark\\SaferpayJson\\": "lib/SaferpayJson/",
            "Ticketpark\\SaferpayJson\\Tests\\": "tests/SaferpayJson/Tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite SaferpayJsonApi",
        "test-integration": [
            "npm --prefix example/PaymentPage/browser ci",
            "npm --prefix example/PaymentPage/browser run install-browsers",
            "phpunit --testsuite integration"
        ],
        "phpstan": "phpstan analyse",
        "rector": "rector process",
        "rector-check": "rector process --dry-run",
        "cs-check": "php-cs-fixer --no-interaction --dry-run --diff fix",
        "cs-fix": "php-cs-fixer --no-interaction fix"
    }
}
